**/.mypy_cache/
apps/backend/.env

# Real credential files (never commit these -- see load_tests/README.md's
# note on FIREBASE_SERVICE_ACCOUNT_JSON_STAGING: it's a GitHub secret's
# VALUE, not a file meant to live in the repo).
*firebase-adminsdk*.json
*-service-account*.json

