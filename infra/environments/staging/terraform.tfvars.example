# Copy this file to terraform.tfvars (gitignored) and fill in real values
# before ever running `terraform plan`/`apply` against this environment.
# Do not commit terraform.tfvars.

gcp_project_id     = "REPLACE_ME"        # GCP project hosting Firestore for this environment
aws_account_suffix = "REPLACE_ME"        # e.g. your AWS account ID, for globally-unique bucket naming

# de-duke.com is an existing, externally-managed Route53 zone + ACM certs
# (see infra/environments/global). Run `terraform apply` there first, then
# paste its outputs here:
acm_certificate_arn     = ""  # `terraform output alb_certificate_arn` from environments/global (eu-west-1, ALB HTTPS listener)
cdn_acm_certificate_arn = ""  # `terraform output cdn_certificate_arn` from environments/global (us-east-1, CloudFront custom domain)

# Admin Web Console (staging-admin.de-duke.com), Vercel-hosted -- unique
# CNAME target per Vercel project, get it from Vercel's dashboard.
# vercel_cname_target = ""
