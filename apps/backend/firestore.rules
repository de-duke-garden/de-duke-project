// firestore.rules -- FEAT-010 (Real-Time Three-Way Support Chat)
//
// Deployed to the project-31cb3884-0cd8-4040-b0c Firebase project's
// `(default)` Firestore database via `firebase deploy --only
// firestore:rules --project project-31cb3884-0cd8-4040-b0c` (run from
// apps/backend/, using firebase.json + .firebaserc in this directory).
// Re-run that command after editing this file to redeploy.
//
// Written against the `conversations/{conversationId}` and
// `conversations/{conversationId}/messages/{messageId}` collections
// described in schema.md's ChatConversation/ChatMessage entities and
// architecture.md's Chat Data Store section.
//
// Auth model, per-role:
//   - De-Duke Staff/Admin (Admin Web Console only) authenticate against
//     Firestore using a custom token minted by POST /v1/chat/token
//     (app/services/chat_service.py::issue_custom_token). That token's
//     `uid` IS the De-Duke `User.id` directly, and carries a `role`
//     claim: "deduke_staff" (mapped server-side from User.role, never
//     trusted from the client).
//   - Consumer roles (Guest, Host, Agency --
//     mobile app only) authenticate with their REAL Firebase
//     Authentication session (Google/email/phone, FEAT-001) -- there is
//     no separate custom-token identity for them. That session's own
//     `request.auth.uid` is Firebase's identity (Google's, etc.), NOT
//     this user's De-Duke `User.id` -- which is what every
//     `clientId`/`propertyManagementId`/`userId`/`senderId` field below
//     actually stores. The backend bridges this by setting a
//     `deduke_user_id` custom claim (plus `role`: "client" |
//     "property_management") on that same Firebase account via
//     POST /v1/chat/sync-claims (app/services/chat_service.py::
//     sync_consumer_claims), called by the mobile client every time chat
//     is entered. Every participant check below reads `deduke_user_id`,
//     never `request.auth.uid` directly, for exactly this reason.

rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    function isSignedIn() {
      return request.auth != null;
    }

    function role() {
      return request.auth.token.role;
    }

    // The De-Duke User.id this Firestore session maps to -- for Staff/
    // Admin, this equals request.auth.uid directly (their custom token's
    // uid IS user.id); for consumer roles, it's the deduke_user_id
    // custom claim POST /v1/chat/sync-claims sets on their real Firebase
    // Authentication account (see this file's header comment).
    function dedukeUserId() {
      return request.auth.token.deduke_user_id;
    }

    function isStaff() {
      // deduke_staff and deduke_admin both map to the "deduke_staff" claim
      // in chat_service.chat_role_for -- staff get full read/write across
      // every conversation for moderation/escalation (FEAT-010, screens.md
      // Screen 22 Chat Oversight Module).
      return isSignedIn() && role() == 'deduke_staff';
    }

    function isParticipant(conversation) {
      return isSignedIn() && (
        dedukeUserId() == conversation.data.clientId ||
        dedukeUserId() == conversation.data.propertyManagementId
      );
    }

    match /conversations/{conversationId} {
      allow read: if isStaff() || isParticipant(resource);

      // Conversation documents are created exclusively server-side via the
      // Firebase Admin SDK (app/services/chat_service.py::create_conversation)
      // so assignedStaffId is guaranteed null and both participant IDs are
      // validated against the Primary Database -- clients never create
      // conversation docs directly.
      allow create: if false;

      // Participants may update conversation-level metadata (e.g. read
      // receipts / lastMessageAt bookkeeping) but never reassign
      // participants or the assigned staff member. Staff may update freely
      // (e.g. assignedStaffId when picking up an escalation).
      allow update: if isStaff() || (
        isParticipant(resource) &&
        request.resource.data.clientId == resource.data.clientId &&
        request.resource.data.propertyManagementId == resource.data.propertyManagementId &&
        request.resource.data.listingId == resource.data.listingId &&
        request.resource.data.assignedStaffId == resource.data.assignedStaffId
      );

      allow delete: if false;

      match /messages/{messageId} {
        allow read: if isStaff() || isParticipant(get(/databases/$(database)/documents/conversations/$(conversationId)));

        // A message may only be authored by one of the two conversation
        // participants (as themselves, never impersonating the other side)
        // or by staff (moderation notes / joining an escalated thread).
        allow create: if isStaff() || (
          isParticipant(get(/databases/$(database)/documents/conversations/$(conversationId))) &&
          request.resource.data.senderId == dedukeUserId()
        );

        // Messages are immutable once sent, except for delivery/read status
        // transitions (sending -> sent -> delivered -> read), which either
        // side of the conversation -- or staff -- may update.
        allow update: if (isStaff() || isParticipant(get(/databases/$(database)/documents/conversations/$(conversationId)))) &&
          request.resource.data.body == resource.data.body &&
          request.resource.data.senderId == resource.data.senderId;

        allow delete: if false;
      }
    }

    // FEAT-029 (General In-App Support / Help, screens.md Screen 26) -- a
    // two-way thread (User <-> De-Duke Staff) not tied to a listing, so it
    // uses userId/status instead of ChatConversation's
    // clientId/propertyManagementId/listingId shape. Otherwise mirrors
    // /conversations exactly: backend-created only, messages immutable
    // except delivery-status transitions.
    function isSupportOwner(conversation) {
      return isSignedIn() && dedukeUserId() == conversation.data.userId;
    }

    match /support_conversations/{conversationId} {
      allow read: if isStaff() || isSupportOwner(resource);

      // Created exclusively server-side (chat_service.get_or_create_support_conversation)
      // so there is at most one conversation per user and userId is always
      // validated against the Primary Database.
      allow create: if false;

      // The owner may reopen a resolved conversation by sending a new
      // message (screens.md Screen 26 edge case: "conversation
      // automatically reopens") -- status and lastMessageAt bookkeeping
      // only, never reassigning userId or assignedStaffId themselves.
      // Staff may update freely (assigning, resolving).
      allow update: if isStaff() || (
        isSupportOwner(resource) &&
        request.resource.data.userId == resource.data.userId &&
        request.resource.data.assignedStaffId == resource.data.assignedStaffId
      );

      allow delete: if false;

      match /messages/{messageId} {
        allow read: if isStaff() || isSupportOwner(get(/databases/$(database)/documents/support_conversations/$(conversationId)));

        allow create: if isStaff() || (
          isSupportOwner(get(/databases/$(database)/documents/support_conversations/$(conversationId))) &&
          request.resource.data.senderId == dedukeUserId()
        );

        allow update: if (isStaff() || isSupportOwner(get(/databases/$(database)/documents/support_conversations/$(conversationId)))) &&
          request.resource.data.body == resource.data.body &&
          request.resource.data.senderId == resource.data.senderId;

        allow delete: if false;
      }
    }
  }
}
