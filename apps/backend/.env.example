# Copy to .env (gitignored) for local development. Populate real values by
# copying them from the AWS Secrets Manager "app-secrets" secret and the
# RDS-managed database secret for your target environment -- never invent
# values here.

DEDUKE_ENVIRONMENT=development

# -- Cross-app links --
ADMIN_CONSOLE_URL=http://localhost:3000

# -- Database (local Postgres with PostGIS + pgvector extensions enabled) --
DATABASE_URL=postgresql+asyncpg://REPLACE_ME:REPLACE_ME@localhost:5432/deduke

# -- Cache --
REDIS_URL=redis://localhost:6379/0

# -- Task Queue --
SQS_QUEUE_URL=REPLACE_ME

# -- File Storage (S3 + CDN) --
# Populate from `terraform output` in the target environment (bucket_name/
# cdn_domain_name, see infra/modules/s3_cdn). Leave both REPLACE_ME/empty
# for docker-compose local dev -- it overrides these itself to point at
# LocalStack (see docker-compose.yml).
MEDIA_BUCKET_NAME=REPLACE_ME
MEDIA_CDN_DOMAIN=REPLACE_ME
AWS_REGION=eu-west-1
AWS_ENDPOINT_URL=
MEDIA_LOCAL_PUBLIC_BASE_URL=

# -- Auth --
JWT_SIGNING_SECRET=REPLACE_ME
JWT_ALGORITHM=HS256

# -- Third-party providers (copy from AWS Secrets Manager "app-secrets") --
PAYSTACK_SECRET_KEY=REPLACE_ME
PAYSTACK_PUBLIC_KEY=REPLACE_ME
PAYSTACK_WEBHOOK_SECRET=REPLACE_ME
GOOGLE_MAPS_API_KEY=REPLACE_ME
FIREBASE_SERVICE_ACCOUNT_JSON=REPLACE_ME
FIRESTORE_PROJECT_ID=REPLACE_ME
FCM_SERVER_KEY=REPLACE_ME
AWS_SES_SENDER_EMAIL=REPLACE_ME
SENTRY_DSN=REPLACE_ME
ANALYTICS_WRITE_KEY=REPLACE_ME
