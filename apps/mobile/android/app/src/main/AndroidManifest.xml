<manifest xmlns:android="http://schemas.android.com/apk/res/android">
    <!-- Required for all network access (Backend API Service, Paystack
         checkout, Firebase/Firestore chat); the debug manifest alone
         only covers debug builds, this is needed for profile/release too. -->
    <uses-permission android:name="android.permission.INTERNET"/>
    <!-- Required by image_picker's ImageSource.camera (Become a Host document
         submission and Create Listing photo grid both require camera/gallery
         pickers per screens.md). Gallery selection via image_picker's
         document-provider intent needs no storage permission on this app's
         target SDK. -->
    <uses-permission android:name="android.permission.CAMERA"/>
    <!-- Required by geolocator's "Use my GPS location" input method on
         Create Listing (screens.md Screen 7's three-method location input).
         COARSE alone is sufficient for a listing's approximate map
         placement, but FINE is requested too since some OEM location
         settings screens only expose an all-or-nothing toggle. -->
    <uses-permission android:name="android.permission.ACCESS_FINE_LOCATION"/>
    <uses-permission android:name="android.permission.ACCESS_COARSE_LOCATION"/>
    <!-- Required on Android 13+ (API 33, this app's targetSdk per
         flutter.targetSdkVersion) for ANY notification to display,
         including FCM push (FEAT-022): without this declared, the OS
         silently drops every notification post-delivery even though FCM
         itself reports a successful send (confirmed: backend
         send_each_for_multicast returns success_count=1 for a registered
         token, yet nothing appears on-device). firebase_messaging's
         FirebaseMessaging.requestPermission() call in
         push_notification_service.dart needs this manifest entry to
         actually surface the runtime prompt/grant. -->
    <uses-permission android:name="android.permission.POST_NOTIFICATIONS"/>

    <application
        android:label="De-Duke"
        android:name="${applicationName}"
        android:icon="@mipmap/ic_launcher">
        <!-- Google Maps SDK key, injected by app/build.gradle.kts's
             manifestPlaceholders from android/local.properties'
             googleMaps.apiKey (gitignored, never committed). Used by
             Search's map view and Create Listing's map-pin picker. -->
        <meta-data
            android:name="com.google.android.geo.API_KEY"
            android:value="${googleMapsApiKey}" />
        <activity
            android:name=".MainActivity"
            android:exported="true"
            android:launchMode="singleTop"
            android:taskAffinity=""
            android:theme="@style/LaunchTheme"
            android:configChanges="orientation|keyboardHidden|keyboard|screenSize|smallestScreenSize|locale|layoutDirection|fontScale|screenLayout|density|uiMode"
            android:hardwareAccelerated="true"
            android:windowSoftInputMode="adjustResize">
            <!-- Specifies an Android theme to apply to this Activity as soon as
                 the Android process has started. This theme is visible to the user
                 while the Flutter UI initializes. After that, this theme continues
                 to determine the Window background behind the Flutter UI. -->
            <meta-data
              android:name="io.flutter.embedding.android.NormalTheme"
              android:resource="@style/NormalTheme"
              />
            <intent-filter>
                <action android:name="android.intent.action.MAIN"/>
                <category android:name="android.intent.category.LAUNCHER"/>
            </intent-filter>
            <!-- Android App Links: after Paystack checkout, the guest's
                 browser is redirected to https://de-duke.com/payment-complete
                 (Settings.marketing_site_url plus the callback_url built in
                 apps/backend/app/api/v1/checkout.py's initiate_checkout).
                 `autoVerify="true"` makes Android confirm this app is the
                 registered handler for that host via
                 apps/marketing-site/public/.well-known/assetlinks.json
                 (Digital Asset Links) at install time, then intercepts any
                 matching https:// navigation, including one opened by
                 url_launcher's external-browser checkout flow, and opens
                 THIS app directly instead of ever rendering the marketing
                 site's fallback page. go_router's '/payment-complete' route
                 (app_router.dart) receives the full URI (path + query
                 params) and redirects into Transaction Detail.
                 IMPORTANT: assetlinks.json's sha256_cert_fingerprints must
                 be updated with this app's real release-signing
                 certificate fingerprint (`keytool -list -v -keystore
                 <release-keystore> | grep SHA256`) before this verifies in
                 production; see that file's own comment. -->
            <intent-filter android:autoVerify="true">
                <action android:name="android.intent.action.VIEW"/>
                <category android:name="android.intent.category.DEFAULT"/>
                <category android:name="android.intent.category.BROWSABLE"/>
                <data android:scheme="https" android:host="de-duke.com" android:pathPrefix="/payment-complete"/>
                <data android:scheme="https" android:host="www.de-duke.com" android:pathPrefix="/payment-complete"/>
            </intent-filter>
        </activity>
        <!-- Don't delete the meta-data below.
             This is used by the Flutter tool to generate GeneratedPluginRegistrant.java -->
        <meta-data
            android:name="flutterEmbedding"
            android:value="2" />
    </application>
    <!-- Required to query activities that can process text, see:
         https://developer.android.com/training/package-visibility and
         https://developer.android.com/reference/android/content/Intent#ACTION_PROCESS_TEXT.

         In particular, this is used by the Flutter engine in io.flutter.plugin.text.ProcessTextPlugin. -->
    <queries>
        <intent>
            <action android:name="android.intent.action.PROCESS_TEXT"/>
            <data android:mimeType="text/plain"/>
        </intent>
        <!-- Required by url_launcher (Android 11+ package visibility) to
             resolve a browser for Paystack checkout / receipt PDF links. -->
        <intent>
            <action android:name="android.intent.action.VIEW"/>
            <data android:scheme="https"/>
        </intent>
    </queries>
</manifest>
