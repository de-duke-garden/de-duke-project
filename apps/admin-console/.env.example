# Copy to .env.local (gitignored) for local development.

# Used server-side by src/lib/auth.ts (getAdminSession) and
# src/app/api/session/route.ts (login) -- includes the /v1 prefix since
# these files append endpoint paths directly (e.g. `${API_BASE_URL}/auth/me`).
NEXT_PUBLIC_API_BASE_URL=http://localhost:8000/v1

# Used server-side ONLY by src/app/api/backend/[...path]/route.ts, the
# proxy every client component calls through (so the httpOnly session
# cookie can be exchanged for an Authorization: Bearer header without ever
# reaching client-side JS). Deliberately NOT NEXT_PUBLIC_-prefixed -- must
# never be bundled into client-side code. Bare origin, no /v1 -- the proxy
# forwards the full path as given by the client (e.g. /api/backend/v1/...).
BACKEND_API_URL=http://localhost:8000
